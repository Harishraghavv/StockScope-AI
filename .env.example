# ============================================
# StockScope AI — Environment Variables
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` to git.
# ============================================

# --- Database (PostgreSQL via Prisma) ---
DATABASE_URL="postgresql://user:password@localhost:5432/stockscope?schema=public"

# --- Auth / JWT ---
# Generate with: openssl rand -base64 48
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="7d"
COOKIE_NAME="stockscope_token"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# --- Market Data Provider (choose one, used in later modules) ---
# Alpha Vantage: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=""
# Twelve Data: https://twelvedata.com/account/api-keys
TWELVE_DATA_API_KEY=""

# --- Live data refresh protection ---
# Any random string — protects /api/live-data/refresh from being triggered
# by strangers on the internet. Generate with: openssl rand -hex 16
CRON_SECRET=""

# --- News API (used in later modules) ---
NEWS_API_KEY=""

# --- AI Provider (used in AI Insights module) ---
# Anthropic (recommended for this project)
ANTHROPIC_API_KEY=""
# or OpenAI-compatible
OPENAI_API_KEY=""

# --- Email (for password reset, used later) ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="noreply@stockscope.ai"
